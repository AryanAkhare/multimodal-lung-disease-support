# Backend Environment Configuration
# Copy this file to .env and update values as needed

# Model Configuration
MODEL_PATH=models/keras/best_global_model.keras
FALLBACK_MODEL_PATH=models/h5/best_global_model.h5

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_LOG_LEVEL=info

# CORS Configuration
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000", "*"]

# Preprocessing
ENABLE_PREPROCESSING=true
SCALER_PATH=artifacts/tabular_scaler.joblib
NUM_IMPUTER_PATH=artifacts/tabular_num_imputer.joblib
CAT_IMPUTER_PATH=artifacts/tabular_cat_imputer.joblib
LABEL_ENCODER_PATH=artifacts/tabular_label_encoder.joblib

# Image Processing
IMAGE_TARGET_SIZE=224
IMAGE_NORMALIZE=true

# Audio Processing
AUDIO_SAMPLE_RATE=22050
AUDIO_DURATION=5.0
AUDIO_N_MFCC=40

# Inference
BATCH_SIZE=1
VERBOSE=false

# Security (for production)
API_KEY_ENABLED=false
API_KEY=your-secret-key-here

# Logging
LOG_LEVEL=info
LOG_FILE=backend.log
